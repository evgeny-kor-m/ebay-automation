{
  "Environment": "Testing",
  "BaseUrl": "https://www.ebay.com",
  "BrowserSettings": {
    "DefaultBrowser": "chrome",
    "Headless": true,
    "SlowMo": 50,
    "Viewport": {
      "Width": 1920,
      "Height": 1080
    },
    "Tracing": true,
    "Video": "on-first-retry"
  },
  "Timeouts": {
    "DefaultTimeout": 30000,
    "NavigationTimeout": 60000
  },
  "Logging": {
    "Level": "DEBUG",
    "ConsoleOutput": true,
    "Propagate" : true,
    "FileOutput": true
  },
   "Paths": {
    "BasetDir": "reports",
    "Screenshots": "screenshots",
    "Logs": "logs",
    "AllureResults": "allure-results",
    "LogFileName": "automation.log",
    "HtmlReports": "html-reports",
    "AllureReports": "allure-reports"
  }
}